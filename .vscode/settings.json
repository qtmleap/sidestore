{
  "gitdoc.enabled": true,
  "gitdoc.commitValidationLevel": "none",
  "gitdoc.autoCommitDelay": 30000,
  "gitdoc.autoPush": "onCommit",
  "gitdoc.ai.model": "gpt-4o",
  "gitdoc.autoPull": "onPush",
  "gitdoc.ai.enabled": true,
  "gitdoc.excludeBranches": [
    "master",
    "develop"
  ],
  "gitdoc.ai.customInstructions": "Generate a commit message in English following the Conventional Commits specification and `commitlint` rules. Use the format `<type>(<scope>): <short description>` and choose `<type>` from `build`, `ci`, `docs`, `feat`, `fix`, `perf`, `chore`, `refactor`, `revert`, `format`, `test`. Limit `<short description>` to 72 characters. If `<short description>` starts with an English word, it must be in lowercase.",
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objectsnode_modules.venvtargetdist.next.wranglernode_modules": true,
    "**/dist": true,
    "**/target": true,
    "**/.venv": true,
    "**/coverage": true,
    "**routeTree.gen.ts": true,
    "**/bun.lock": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/yarn.lock": true,
    "**/uv.lock": true,
    "**/poetry.lock": true,
    "**/Cargo.lock": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "betterTypeScriptErrors.prettify": true,
  "debug.internalConsoleOptions": "neverOpen",
  "diffEditor.diffAlgorithm": "advanced",
  "diffEditor.experimental.showMoves": true,
  "diffEditor.renderSideBySide": true,
  "editor.formatOnPaste": false,
  "editor.guides.bracketPairs": "active",
  "editor.codeActionsOnSave": {
    "quickfix.biome": "explicit",
    "source.organizeImports.biome": "explicit",
    "source.fixAll.biome": "explicit"
  },
  "editor.formatOnSave": true,
  "scm.defaultViewMode": "tree",
  "editor.tabSize": 2,
  "editor.rulers": [
    100,
    120
  ],
  "editor.renderWhitespace": "boundary",
  "editor.stickyScroll.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.git": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/target": true,
    "**/dist": true,
    "**/.next": true,
    "**/.nuxt": true,
    "**/.svelte-kit": true,
    "**/.turbo": true,
    "**/.wrangler": true,
    "**/.cache": true,
    "**/.parcel-cache": true,
    "**/coverage": true,
    "**/.nyc_output": true,
    "**/.tanstack": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, pnpm-lock.yaml, yarn.lock, bun.lock, bun.lockb, .npmrc, .nvmrc, .node-version, tsconfig*.json, biome.json, .biomeignore, .prettier*, .eslintrc*, vite.config*, vitest.config*, wrangler.toml, wrangler.jsonc",
    "pyproject.toml": "uv.lock, poetry.lock, requirements*.txt, .python-version, ruff.toml, .ruff.toml, mypy.ini",
    "Cargo.toml": "Cargo.lock, rust-toolchain*, rustfmt.toml, .cargo/config.toml",
    "Package.swift": "Package.resolved, .swift-version, .swiftformat",
    "Dockerfile": "compose.yaml, compose.*.yaml, docker-compose.yml, docker-compose.*.yml, .dockerignore",
    ".gitignore": ".gitattributes",
    "README.md": "CHANGELOG.md, LICENSE*, CONTRIBUTING.md, CODE_OF_CONDUCT.md, SECURITY.md, AUTHORS*",
    "*.ts": "$(capture).test.ts, $(capture).spec.ts, $(capture).d.ts",
    "*.tsx": "$(capture).test.tsx, $(capture).spec.tsx, $(capture).module.css"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.pruneOnFetch": true,
  "git.branchProtection": [
    "main",
    "master",
    "develop"
  ],
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[markdown]": {
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true
}
